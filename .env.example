# ── Contact form (Resend) ─────────────────────────────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact submissions are delivered.
# On Resend's free tier WITHOUT a verified domain, this MUST be the email
# you signed up to Resend with. Defaults to the address in data/content.ts.
CONTACT_TO_EMAIL=akanaiyalalp@mun.ca

# Sender address. Leave as-is to use Resend's shared sender (no domain setup).
# Once you verify your own domain in Resend, change this to e.g.
# "Aksh Patel <hello@yourdomain.com>".
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>

# ── SEO ───────────────────────────────────────────────────────────────
# Your real production URL (no trailing slash). Used for sitemap, canonical
# tags and Open Graph. Set this in Vercel to your live domain.
NEXT_PUBLIC_SITE_URL=https://www.axsh.me

# Google Search Console verification token (HTML-tag method).
# Paste only the content value of the meta tag Google gives you.
GOOGLE_SITE_VERIFICATION=

# ── CMS (Sanity) ──────────────────────────────────────────────────────
# Public values (safe to expose). The editor lives at /admin.
NEXT_PUBLIC_SANITY_PROJECT_ID=480o7clx
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
